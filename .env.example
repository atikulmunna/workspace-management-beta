PORT=3000
NODE_ENV=development

# PostgreSQL (get from Neon: https://neon.tech)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.aws.neon.tech/neondb?sslmode=require"

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRES_IN="15m"

# Refresh Token
REFRESH_TOKEN_EXPIRES_DAYS=30

# Magic Link
MAGIC_LINK_EXPIRES_MINUTES=15

# Email — Resend SMTP (https://resend.com)
# SMTP_PASS: your Resend API key (re_xxxx...)
# EMAIL_FROM: onboarding@resend.dev (free) or noreply@yourdomain.com (after domain verify)
SMTP_HOST="smtp.resend.com"
SMTP_PORT=465
SMTP_USER="resend"
SMTP_PASS="re_REPLACE_WITH_RESEND_API_KEY"
EMAIL_FROM="onboarding@resend.dev"

# App — public base URL used in email links
APP_URL="http://localhost:3000"
