PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/workspace_service"

# JWT — use a long random secret (min 32 chars)
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-this-to-a-long-random-secret-before-deploying"
JWT_EXPIRES_IN="7d"

# Magic Link
MAGIC_LINK_EXPIRES_MINUTES=15

# Email (for magic links + invitations)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="you@example.com"
SMTP_PASS="yourpassword"
EMAIL_FROM="noreply@yourapp.com"

# App
APP_URL="http://localhost:3000"
