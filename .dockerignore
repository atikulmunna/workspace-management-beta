# ── Dependency artifacts ───────────────────────────────────────────────────
node_modules/

# ── Environment files (never in image) ────────────────────────────────────
.env
.env.*

# ── Development / build tooling ────────────────────────────────────────────
*.log
logs/
.DS_Store
Thumbs.db

# ── Git / CI ───────────────────────────────────────────────────────────────
.git/
.github/

# ── Test files ─────────────────────────────────────────────────────────────
src/__tests__/
jest.config.ts
jest.integration.config.ts
docker-compose*.yml

# ── Documentation ──────────────────────────────────────────────────────────
*.md
workspace-service-srs.md

# NOTE: src/, *.ts, tsconfig.json, and prisma/ are intentionally NOT excluded
# so the builder stage can compile TypeScript and generate the Prisma client.
